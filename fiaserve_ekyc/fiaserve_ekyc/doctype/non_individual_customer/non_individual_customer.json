{
  "name": "Non-Individual Customer",
  "module": "FIASERVE EKYC",
  "doctype": "DocType",
  "autoname": "format:NIC-{YYYY}-{#####}",
  "title_field": "entity_name",
  "fields": [
    {
      "fieldname": "section_entity",
      "fieldtype": "Section Break",
      "label": "Entity Information"
    },
    {
      "fieldname": "entity_name",
      "fieldtype": "Data",
      "label": "Full Name of Customer (Entity)",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "entity_type",
      "fieldtype": "Select",
      "label": "Entity Type",
      "options": "Company\nTrust\nPartnership\nFoundation\nAssociation\nOther",
      "reqd": 1
    },
    {
      "fieldname": "registration_number",
      "fieldtype": "Data",
      "label": "Registration / Incorporation Number",
      "reqd": 1
    },
    {
      "fieldname": "date_of_incorporation",
      "fieldtype": "Date",
      "label": "Date of Incorporation"
    },
    {
      "fieldname": "place_of_incorporation",
      "fieldtype": "Data",
      "label": "Place of Incorporation"
    },
    {
      "fieldname": "country_of_incorporation",
      "fieldtype": "Link",
      "label": "Country of Incorporation",
      "options": "Country",
      "reqd": 1
    },
    {
      "fieldname": "head_office_address",
      "fieldtype": "Text",
      "label": "Head Office Address",
      "reqd": 1
    },
    {
      "fieldname": "country_of_operations",
      "fieldtype": "Link",
      "label": "Place / Country of Business Operations",
      "options": "Country"
    },
    {
      "fieldname": "risk_level",
      "fieldtype": "Select",
      "label": "Risk Level",
      "options": "Low\nMedium\nHigh\nVery High",
      "default": "Low",
      "in_list_view": 1
    },
    {
      "fieldname": "section_principals",
      "fieldtype": "Section Break",
      "label": "Directors / Shareholders / Trustees / Beneficiaries"
    },
    {
      "fieldname": "principals_table",
      "fieldtype": "Table",
      "label": "Principals",
      "options": "NIC Principal"
    },
    {
      "fieldname": "section_representative",
      "fieldtype": "Section Break",
      "label": "Customer Representative (Where Applicable)"
    },
    {
      "fieldname": "has_representative",
      "fieldtype": "Check",
      "label": "Has Customer Representative"
    },
    {
      "fieldname": "representative_name",
      "fieldtype": "Data",
      "label": "Full Name of Representative",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "representative_capacity",
      "fieldtype": "Select",
      "label": "Capacity / Role",
      "options": "Director\nShareholder\nTrustee\nSettlor\nBeneficiary\nPower of Attorney\nLegal Guardian\nOther",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "section_funds",
      "fieldtype": "Section Break",
      "label": "Source of Funds & Tax"
    },
    {
      "fieldname": "source_of_funds",
      "fieldtype": "Select",
      "label": "Source of Funds",
      "options": "Employment Income\nBusiness Income\nInvestment Returns\nPension / Retirement\nInheritance\nGift\nSale of Property\nSale of Business\nLoan\nGovernment Grant\nOther",
      "reqd": 1
    },
    {
      "fieldname": "source_of_funds_details",
      "fieldtype": "Text",
      "label": "Source of Funds - Details"
    },
    {
      "fieldname": "tax_status",
      "fieldtype": "Data",
      "label": "Tax Status / TIN Number"
    },
    {
      "fieldname": "tax_compliance_notes",
      "fieldtype": "Text",
      "label": "Tax Compliance Notes"
    },
    {
      "fieldname": "section_screening",
      "fieldtype": "Section Break",
      "label": "Sanctions & PEP Screening"
    },
    {
      "fieldname": "sanctions_status",
      "fieldtype": "Select",
      "label": "Screening Status",
      "options": "Pending\nClear\nMatch Found\nReview Required",
      "default": "Pending",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sanctions_screened_on",
      "fieldtype": "Datetime",
      "label": "Last Screened On",
      "read_only": 1
    },
    {
      "fieldname": "section_documents",
      "fieldtype": "Section Break",
      "label": "Supporting Documents"
    },
    {
      "fieldname": "certificate_of_incorporation",
      "fieldtype": "Attach",
      "label": "Certificate of Incorporation"
    },
    {
      "fieldname": "cr6_document",
      "fieldtype": "Attach",
      "label": "CR6 (Directors Register)"
    },
    {
      "fieldname": "cr2_document",
      "fieldtype": "Attach",
      "label": "CR2 (Shareholders Register)"
    },
    {
      "fieldname": "memo_articles",
      "fieldtype": "Attach",
      "label": "Memorandum & Articles of Association"
    },
    {
      "fieldname": "trust_deed",
      "fieldtype": "Attach",
      "label": "Trust Deed (If applicable)"
    },
    {
      "fieldname": "company_profile",
      "fieldtype": "Attach",
      "label": "Company Profile / Prospectus"
    },
    {
      "fieldname": "source_of_funds_doc",
      "fieldtype": "Attach",
      "label": "Source of Funds Document (Bank Statement / Audited Financials / Letter)"
    },
    {
      "fieldname": "tax_returns_doc",
      "fieldtype": "Attach",
      "label": "Tax Returns / Capital Gains Tax Document"
    },
    {
      "fieldname": "representative_auth_doc",
      "fieldtype": "Attach",
      "label": "Representative Authorisation Document",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "directors_id_docs",
      "fieldtype": "Attach",
      "label": "Directors / Principals ID Documents"
    },
    {
      "fieldname": "section_meta",
      "fieldtype": "Section Break",
      "label": "Record Metadata"
    },
    {
      "fieldname": "kyc_officer",
      "fieldtype": "Link",
      "label": "KYC Officer",
      "options": "User"
    },
    {
      "fieldname": "capture_date",
      "fieldtype": "Date",
      "label": "Capture Date",
      "default": "Today"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Additional Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "search_fields": "entity_name,registration_number",
  "is_submittable": 0
}
