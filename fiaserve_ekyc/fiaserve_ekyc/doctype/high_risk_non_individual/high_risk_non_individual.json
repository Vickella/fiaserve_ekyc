    {
      "fieldname": "source_of_funds_details",
      "fieldtype": "Text",
      "label": "Source of Funds - Details",
      "reqd": 1
    },
    {
      "fieldname": "tax_status",
      "fieldtype": "Data",
      "label": "Tax Status / TIN Number",
      "reqd": 1
