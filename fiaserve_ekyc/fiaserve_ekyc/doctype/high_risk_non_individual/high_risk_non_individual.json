      "mandatory_depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "section_funds",
      "fieldtype": "Section Break",
      "label": "Source of Funds & Tax"
    },
    {
      "fieldname": "source_of_funds",
      "fieldtype": "Select",
      "label": "Source of Funds",
      "options": "Employment Income\nBusiness Income\nInvestment Returns\nPension / Retirement\nInheritance\nGift\nSale of Property\nSale of Business\nLoan\nGovernment Grant\nOther",
      "reqd": 1
