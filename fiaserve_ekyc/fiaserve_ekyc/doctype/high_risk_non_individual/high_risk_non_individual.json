    {
      "fieldname": "industry",
      "fieldtype": "Link",
      "label": "Industry",
      "options": "KYC Industry",
      "reqd": 1
    },
    {
      "fieldname": "occupation",
      "fieldtype": "Link",
      "label": "Occupation",
      "options": "KYC Occupation",
      "reqd": 1
    },
    {
      "fieldname": "customer_type",
      "fieldtype": "Link",
      "label": "Customer Type",
      "options": "KYC Customer Type",
      "reqd": 1
    },
    {
