      "options": "User"
    },
    {
      "fieldname": "capture_date",
      "fieldtype": "Date",
      "label": "Capture Date",
      "default": "Today"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Additional Notes",
      "reqd": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "search_fields": "entity_name,registration_number",
  "is_submittable": 0
}