      "read_only": 1
    },
    {
      "fieldname": "pep_identified",
      "fieldtype": "Check",
      "label": "PEP Identified",
      "read_only": 1
    },
    {
      "fieldname": "on_sanctions_list",
      "fieldtype": "Check",
      "label": "On Sanctions Lists",
      "read_only": 1
    },
    {
      "fieldname": "pep_sanctions_status",
      "fieldtype": "Link",
      "label": "PEP / Sanctions Risk Status",
      "options": "KYC PEP Sanctions Status",
      "read_only": 1,
      "default": "Not Screened"
    },
    {
      "fieldname": "sanctions_screened_on",
      "fieldtype": "Datetime",
      "label": "Last Screened On",
      "read_only": 1
    },
    {
      "fieldname": "api_query",
      "fieldtype": "Data",
      "label": "API Query String",
      "read_only": 1
    },
    {
      "fieldname": "match_found",
      "fieldtype": "Check",
      "label": "Match Found",
      "read_only": 1
    },
    {
      "fieldname": "total_results",
      "fieldtype": "Int",
      "label": "Total API Results",
      "read_only": 1
    },
    {
      "fieldname": "matches_table",
      "fieldtype": "Table",
      "label": "Matched Entities",
      "options": "Sanctions Match Entry",
      "read_only": 1
    },
    {
      "fieldname": "raw_api_response",
      "fieldtype": "Code",
      "label": "Raw JSON Response",
      "options": "JSON",
      "read_only": 1
    },
    {
      "fieldname": "risk_assessment",
      "fieldtype": "Select",
      "label": "Risk Assessment Outcome",
      "options": "Clear\nMatch Found\nReview Required\nFalse Positive",
      "read_only": 1
    },
    {
      "fieldname": "assessed_by",
      "fieldtype": "Link",
      "label": "Assessed By",
      "options": "User"
    },
    {
      "fieldname": "assessment_notes",
      "fieldtype": "Text",
      "label": "Assessment Notes"
    },
    {
      "fieldname": "tab_risk_rating",
      "fieldtype": "Tab Break",
      "label": "Risk Rating"
    },
    {
      "fieldname": "industry_risk_score",
      "fieldtype": "Int",
      "label": "Industry Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "occupation_risk_score",
      "fieldtype": "Int",
      "label": "Occupation Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "customer_type_risk_score",
      "fieldtype": "Int",
      "label": "Customer Type Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "country_risk_score",
      "fieldtype": "Int",
      "label": "Country / Jurisdiction Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "pep_sanctions_risk_score",
      "fieldtype": "Int",
      "label": "PEP / Sanctions Status Risk Score",
      "read_only": 1
    },
    {
      "fieldname": "final_risk_score",
      "fieldtype": "Float",
      "label": "Final Risk Score",
      "precision": "2",
      "read_only": 1
