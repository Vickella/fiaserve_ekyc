      "label": "Senior Management Approval Obtained",
      "reqd": 1
    },
    {
      "fieldname": "approving_officer",
      "fieldtype": "Data",
      "label": "Name of Approving Officer",
      "reqd": 1
    },
    {
      "fieldname": "approval_date",
      "fieldtype": "Date",
      "label": "Approval Date",
      "reqd": 1
    },
    {
      "fieldname": "approval_notes",
      "fieldtype": "Text",
      "label": "Approval Notes / Justification",
      "reqd": 1
    },
    {
      "fieldname": "senior_mgmt_signoff_doc",
      "fieldtype": "Attach",
      "label": "Senior Management Sign-Off Document"
    },
    {
      "fieldname": "section_documents",
      "fieldtype": "Section Break",
      "label": "Supporting Documents"
    },
    {
      "fieldname": "certificate_of_incorporation",
      "fieldtype": "Attach",
      "label": "Certificate of Incorporation"
    },
    {
      "fieldname": "cr6_document",
      "fieldtype": "Attach",
      "label": "CR6 (Directors Register)"
    },
    {
      "fieldname": "cr2_document",
      "fieldtype": "Attach",
      "label": "CR2 (Shareholders Register)"
    },
    {
      "fieldname": "memo_articles",
      "fieldtype": "Attach",
      "label": "Memorandum & Articles of Association"
    },
    {
      "fieldname": "trust_deed",
      "fieldtype": "Attach",
      "label": "Trust Deed (If applicable)"
    },
    {
      "fieldname": "company_profile",
      "fieldtype": "Attach",
      "label": "Company Profile / Prospectus"
    },
    {
      "fieldname": "source_of_funds_doc",
      "fieldtype": "Attach",
      "label": "Source of Funds Document (Bank Statement / Audited Financials / Letter)"
    },
    {
      "fieldname": "tax_returns_doc",
      "fieldtype": "Attach",
      "label": "Tax Returns / Capital Gains Tax Document"
    },
    {
      "fieldname": "representative_auth_doc",
      "fieldtype": "Attach",
      "label": "Representative Authorisation Document",
      "depends_on": "eval:doc.has_representative==1",
      "mandatory_depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "directors_id_docs",
      "fieldtype": "Attach",
      "label": "Directors / Principals ID Documents"
    },
    {
      "fieldname": "tab_sanction_screening",
      "fieldtype": "Tab Break",
      "label": "Sanction Screening"
