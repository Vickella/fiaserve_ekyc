{
  "name": "Individual Customer",
  "module": "FIASERVE EKYC",
  "doctype": "DocType",
  "autoname": "format:IND-{YYYY}-{#####}",
  "title_field": "full_name",
  "fields": [
    {
      "fieldname": "section_personal",
      "fieldtype": "Section Break",
      "label": "Personal Information"
    },
    {
      "fieldname": "full_name",
      "fieldtype": "Data",
      "label": "Full Name of Customer",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "date_of_birth",
      "fieldtype": "Date",
      "label": "Date of Birth",
      "reqd": 1
    },
    {
      "fieldname": "id_document_type",
      "fieldtype": "Select",
      "label": "ID Document Type",
      "options": "National ID\nPassport\nDriver's Licence\nResidence Permit\nWork Permit\nRefugee Document\nOther",
      "reqd": 1
    },
    {
      "fieldname": "national_id_number",
      "fieldtype": "Data",
      "label": "ID / Passport Number",
      "reqd": 1
    },
    {
      "fieldname": "place_of_birth",
      "fieldtype": "Data",
      "label": "Place of Birth"
    },
    {
      "fieldname": "country_of_birth",
      "fieldtype": "Link",
      "label": "Country of Birth",
      "options": "Country"
    },
    {
      "fieldname": "country_of_residence",
      "fieldtype": "Link",
      "label": "Country of Residence",
      "options": "Country",
      "reqd": 1
    },
    {
      "fieldname": "residential_address",
      "fieldtype": "Text",
      "label": "Residential Address",
      "reqd": 1
    },
    {
      "fieldname": "risk_level",
      "fieldtype": "Select",
      "label": "Risk Level",
      "options": "Low\nMedium\nHigh\nVery High",
      "default": "Low",
      "in_list_view": 1
    },
    {
      "fieldname": "section_representative",
      "fieldtype": "Section Break",
      "label": "Customer Representative (Where Applicable)"
    },
    {
      "fieldname": "has_representative",
      "fieldtype": "Check",
      "label": "Has Customer Representative"
    },
    {
      "fieldname": "representative_name",
      "fieldtype": "Data",
      "label": "Full Name of Representative",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "representative_id_type",
      "fieldtype": "Select",
      "label": "Representative ID Type",
      "options": "National ID\nPassport\nDriver's Licence\nResidence Permit\nWork Permit\nRefugee Document\nOther",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "representative_id_number",
      "fieldtype": "Data",
      "label": "Representative ID Number",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "representative_capacity",
      "fieldtype": "Select",
      "label": "Capacity / Role",
      "options": "Director\nShareholder\nTrustee\nSettlor\nBeneficiary\nPower of Attorney\nLegal Guardian\nOther",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "section_funds",
      "fieldtype": "Section Break",
      "label": "Source of Funds"
    },
    {
      "fieldname": "source_of_funds",
      "fieldtype": "Select",
      "label": "Source of Funds",
      "options": "Employment Income\nBusiness Income\nInvestment Returns\nPension / Retirement\nInheritance\nGift\nSale of Property\nSale of Business\nLoan\nGovernment Grant\nOther",
      "reqd": 1
    },
    {
      "fieldname": "source_of_funds_details",
      "fieldtype": "Text",
      "label": "Source of Funds - Details"
    },
    {
      "fieldname": "section_screening",
      "fieldtype": "Section Break",
      "label": "Sanctions & PEP Screening"
    },
    {
      "fieldname": "sanctions_status",
      "fieldtype": "Select",
      "label": "Screening Status",
      "options": "Pending\nClear\nMatch Found\nReview Required",
      "default": "Pending",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sanctions_screened_on",
      "fieldtype": "Datetime",
      "label": "Last Screened On",
      "read_only": 1
    },
    {
      "fieldname": "section_documents",
      "fieldtype": "Section Break",
      "label": "Supporting Documents"
    },
    {
      "fieldname": "id_document_upload",
      "fieldtype": "Attach",
      "label": "ID Document / Passport / Permit"
    },
    {
      "fieldname": "proof_of_address",
      "fieldtype": "Attach",
      "label": "Proof of Residential Address"
    },
    {
      "fieldname": "source_of_funds_doc",
      "fieldtype": "Attach",
      "label": "Source of Funds Document"
    },
    {
      "fieldname": "representative_auth_doc",
      "fieldtype": "Attach",
      "label": "Representative Authorisation Document",
      "depends_on": "eval:doc.has_representative==1"
    },
    {
      "fieldname": "section_meta",
      "fieldtype": "Section Break",
      "label": "Record Metadata"
    },
    {
      "fieldname": "kyc_officer",
      "fieldtype": "Link",
      "label": "KYC Officer",
      "options": "User"
    },
    {
      "fieldname": "capture_date",
      "fieldtype": "Date",
      "label": "Capture Date",
      "default": "Today"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Additional Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "All",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ],
  "search_fields": "full_name,national_id_number",
  "is_submittable": 0
}
